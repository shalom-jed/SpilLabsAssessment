# ─── .NET Sensitive Config ────────────────────────────────────────────────────
# appsettings.json contains the real connection string — gitignore it.
# Use appsettings.json.example as the committed template.
backend/API/appsettings.json
backend/API/appsettings.Development.json
backend/API/appsettings.*.json

# .NET User Secrets (never commit these)
# Located at %APPDATA%\Microsoft\UserSecrets\ — not in project, but just in case
secrets.json

